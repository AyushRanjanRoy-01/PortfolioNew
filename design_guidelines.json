{
  "identity": {
    "persona": "E1: The Anti-AI Designer",
    "tone": "Deep Space, Cosmic, Minimalist, High-Performance",
    "philosophy": [
      "Fusion over Imitation",
      "Emotion First",
      "Content is King",
      "Zoom In",
      "Negative Space",
      "Contrast"
    ]
  },
  "typography": {
    "font_families": {
      "headings": "Unbounded, sans-serif",
      "body": "Inter, sans-serif",
      "ui": "Rajdhani, sans-serif",
      "mono": "JetBrains Mono, monospace"
    },
    "scaling": {
      "h1": "text-5xl md:text-7xl font-bold tracking-tight",
      "h2": "text-4xl md:text-5xl font-semibold tracking-tight",
      "h3": "text-2xl md:text-3xl font-medium",
      "body": "text-base md:text-lg leading-relaxed",
      "caption": "text-sm tracking-wider uppercase opacity-70"
    },
    "imports": [
      "https://fonts.googleapis.com/css2?family=Unbounded:wght@300;400;600;800&family=Inter:wght@300;400;500;600&family=Rajdhani:wght@400;500;600;700&family=JetBrains+Mono:wght@400&display=swap"
    ]
  },
  "colors": {
    "palette": {
      "background": {
        "default": "#0A0A0F",
        "paper": "#12121A",
        "subtle": "#1A1A24"
      },
      "primary": {
        "main": "#00D4AA",
        "light": "#5EEAD4",
        "dark": "#009678",
        "glow": "0 0 20px rgba(0, 212, 170, 0.5)"
      },
      "secondary": {
        "main": "#7B61FF",
        "light": "#A795FF",
        "dark": "#5236D9",
        "glow": "0 0 20px rgba(123, 97, 255, 0.5)"
      },
      "text": {
        "primary": "#E8E8ED",
        "secondary": "#9494A0",
        "muted": "#5F5F6E"
      },
      "status": {
        "success": "#00D4AA",
        "error": "#FF3B30",
        "warning": "#FFD60A",
        "info": "#007AFF"
      }
    },
    "gradients": {
      "nebula": "radial-gradient(circle at 50% 50%, rgba(123, 97, 255, 0.15), rgba(0, 212, 170, 0.05), transparent 70%)",
      "glass": "linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.01) 100%)",
      "border": "linear-gradient(to bottom right, rgba(255, 255, 255, 0.2), rgba(255, 255, 255, 0.05))"
    }
  },
  "layout": {
    "spacing": {
      "container": "max-w-7xl mx-auto px-6 md:px-12",
      "section_gap": "py-24 md:py-32",
      "element_gap": "gap-8"
    },
    "grid_system": {
      "bento": "grid grid-cols-1 md:grid-cols-8 lg:grid-cols-12 gap-6",
      "projects": "grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8",
      "blog": "grid grid-cols-1 md:grid-cols-12 gap-12"
    },
    "z_index": {
      "stars": "-10",
      "nebula": "-5",
      "content": "10",
      "nav": "50",
      "modal": "100",
      "cursor": "9999"
    }
  },
  "components": {
    "glass_card": {
      "base": "backdrop-blur-xl bg-white/5 border border-white/10 rounded-2xl shadow-xl",
      "hover": "hover:bg-white/10 hover:border-white/20 hover:shadow-2xl transition-all duration-300 group"
    },
    "buttons": {
      "primary": "bg-[#00D4AA] text-[#0A0A0F] font-semibold px-8 py-3 rounded-full hover:bg-[#5EEAD4] transition-transform active:scale-95 shadow-[0_0_20px_rgba(0,212,170,0.3)] hover:shadow-[0_0_30px_rgba(0,212,170,0.5)]",
      "outline": "border border-[#00D4AA] text-[#00D4AA] px-8 py-3 rounded-full hover:bg-[#00D4AA]/10 transition-all active:scale-95"
    },
    "inputs": {
      "base": "bg-white/5 border border-white/10 rounded-lg px-4 py-3 text-[#E8E8ED] placeholder:text-white/20 focus:border-[#00D4AA] focus:ring-1 focus:ring-[#00D4AA] outline-none transition-all"
    },
    "animations": {
      "fade_in": "opacity-0 animate-in fade-in duration-700",
      "slide_up": "translate-y-8 animate-in slide-in-from-bottom-8 fade-in duration-700",
      "star_twinkle": "animate-pulse"
    }
  },
  "sections": {
    "hero": {
      "type": "Immersive Center",
      "elements": ["Name (H1)", "Role (Typewriter Effect)", "Cosmic Visual", "CTAs"],
      "background": "Animated Starfield (tsparticles)"
    },
    "about": {
      "type": "Asymmetric Story",
      "layout": "Text Left, Visual Right (or vice versa)",
      "features": ["Tech Stack Orbit", "Bio Timeline"]
    },
    "projects": {
      "type": "Bento Grid (Mode A)",
      "features": ["Filter Tabs", "Glass Cards", "Hover Glow Effects"]
    },
    "blog": {
      "type": "Minimalist List",
      "features": ["Search Bar", "Tag Filters", "Read Time"]
    },
    "contact": {
      "type": "Glass Panel",
      "features": ["Form", "Social Links", "Floating WhatsApp"]
    }
  },
  "assets": {
    "icons": "Lucide React (use thin stroke width: 1.5)",
    "images": {
      "profile": "Use 'professional portrait dark lighting' query",
      "projects": "Use 'abstract tech visualization' or specific project queries",
      "blog": "Use 'cosmic minimalist abstract' queries"
    }
  },
  "technical_requirements": {
    "libraries_to_install": [
      "framer-motion",
      "@tsparticles/react",
      "@tsparticles/slim",
      "clsx",
      "tailwind-merge"
    ],
    "css_rules": [
      "No pure black (#000000) backgrounds",
      "No default scrollbars (custom styling required)",
      "Selection color: bg-[#00D4AA] text-[#0A0A0F]"
    ]
  },
  "accessibility": {
    "contrast": "Ensure text is #E8E8ED on dark backgrounds",
    "focus": "Visible ring-2 ring-[#00D4AA] on focus",
    "reduced_motion": "Disable particle animation if prefers-reduced-motion is true"
  },
  "instructions_to_main_agent": [
    "1. Install required libraries: `yarn add framer-motion @tsparticles/react @tsparticles/slim`.",
    "2. Configure Tailwind with the colors and fonts provided above.",
    "3. Create a 'Starfield' component using tsparticles that sits at z-index -1.",
    "4. Build the 'Hero' section with a high-impact centered layout.",
    "5. Use 'framer-motion' for all entry animations (stagger children).",
    "6. Ensure the 'Admin' panel is functional but keeps the cosmic theme (maybe simplified).",
    "7. Whatsapp button should be fixed at bottom-right.",
    "8. Use Glassmorphism for all cards and panels."
  ]
}